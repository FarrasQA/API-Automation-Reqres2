<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SmokeTestSuite" verbose="1">

    <listeners>
        <listener class-name="core.TestListener"/>
    </listeners>

    <test name="SmokeTest">

        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>

        <classes>
            <class name="tests.GetSingleUserTest"/>
        </classes>

    </test>

</suite>